FROM python:3.11-slim-bookworm

WORKDIR /app

# Copy requirements and install Python dependencies (no gcc needed: cryptography/bcrypt have wheels)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend code
COPY . .

# Expose port
EXPOSE 8001

# Run the application
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8001", "--reload"]